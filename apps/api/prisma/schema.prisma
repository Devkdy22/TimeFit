generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  authIdentities  AuthIdentity[]
  oauthLoginTickets OAuthLoginTicket[]
  authSessions    AuthSession[]
  devices         Device[]
  idempotencyKeys IdempotencyKey[]
  places          Place[]
  preferences     Preference[]
  recommendations Recommendation[]
  routines        Routine[]
  savedPlaces     SavedPlace[]
  trips           Trip[]
  notifications   Notification[]
}

model AuthIdentity {
  id              String   @id @default(cuid())
  userId          String
  provider        String
  providerUserId  String
  email           String
  name            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model AuthSession {
  id                String    @id @default(cuid())
  userId            String
  accessTokenHash   String    @unique
  refreshTokenHash  String    @unique
  accessExpiresAt   DateTime
  refreshExpiresAt  DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshExpiresAt])
}

model OAuthState {
  id          String    @id @default(cuid())
  provider    String
  stateHash   String    @unique
  returnTo    String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([provider])
  @@index([expiresAt])
}

model OAuthLoginTicket {
  id          String    @id @default(cuid())
  ticketHash  String    @unique
  userId      String
  sessionId   String?
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Device {
  id         String   @id @default(cuid())
  userId     String
  platform   String
  pushToken  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Place {
  id         String   @id @default(cuid())
  userId     String
  label      String
  lat        Float
  lng        Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Preference {
  id             String   @id @default(cuid())
  userId         String
  prepMinutes    Int      @default(10)
  bufferMinutes  Int      @default(8)
  quietArrival   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Recommendation {
  id                 String                @id @default(cuid())
  userId             String
  arrivalAt          DateTime
  departureAt        DateTime
  totalEstimatedMin  Int
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  routes             RecommendationRoute[]
  trips              Trip[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RecommendationRoute {
  id                String   @id @default(cuid())
  recommendationId  String
  provider          String
  mode              String
  durationMin       Int
  score             Float?
  createdAt         DateTime @default(now())

  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([recommendationId])
}

model Routine {
  id                          String    @id @default(cuid())
  userId                      String
  title                       String
  originName                  String
  originLat                   Float
  originLng                   Float
  destinationName             String
  destinationLat              Float
  destinationLng              Float
  weekdays                    Int[]
  arrivalTime                 String
  notificationEnabled         Boolean   @default(true)
  notificationMinutesBefore   Int       @default(10)
  favorite                    Boolean   @default(false)
  active                      Boolean   @default(true)
  savedRoute                  Json?
  expoPushToken               String?
  lastTriggeredAt             DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
}

model Trip {
  id                   String         @id @default(cuid())
  userId               String
  recommendationId     String
  status               String         @default("preparing")
  startedAt            DateTime
  expectedArrivalAt    DateTime?
  plannedDurationMin   Int?
  delayOffsetMin       Int            @default(0)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendation  Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recommendationId])
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  tripId       String?
  channel      String   @default("push")
  status       String   @default("scheduled")
  scheduledAt  DateTime
  sentAt       DateTime?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TrafficSnapshot {
  id              String   @id @default(cuid())
  key             String
  congestionIndex Float
  ttlSeconds      Int
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([key, expiresAt])
}

model OdsayUsageDaily {
  id                  String   @id @default(cuid())
  date                String   @unique
  timezone            String   @default("Asia/Seoul")
  totalRequests       Int      @default(0)
  externalApiCalls    Int      @default(0)
  cacheHits           Int      @default(0)
  staleFallbackHits   Int      @default(0)
  deduplicatedRequests Int     @default(0)
  successResponses    Int      @default(0)
  failedResponses     Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SavedPlace {
  id        String   @id @default(cuid())
  userId    String
  label     String
  normalizedLabel String
  address   String
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, normalizedLabel])
}

model IdempotencyKey {
  id               String            @id @default(cuid())
  userId           String
  scope            String
  key              String
  payloadHash      String
  status           IdempotencyStatus @default(PENDING)
  responseSnapshot Json?
  expiresAt        DateTime
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope, key])
  @@index([expiresAt])
  @@index([userId, scope])
}

enum IdempotencyStatus {
  PENDING
  COMPLETED
  FAILED
}
