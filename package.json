{
  "name": "timefit",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @timefit/api dev",
    "dev:mobile": "pnpm --filter @timefit/mobile dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "prisma:generate": "pnpm --filter @timefit/api prisma:generate",
    "prisma:migrate": "pnpm --filter @timefit/api prisma:migrate"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  }
}
